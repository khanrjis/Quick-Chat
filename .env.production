# Production Environment Variables
# This file is for reference only. Do NOT commit this to Git.
# Set these variables in your Render and Vercel dashboards instead.

# Render Backend - Set in Render Dashboard
PORT=10000
GOOGLE_GENERATIVE_AI_KEY=your_actual_google_api_key

# Vercel Frontend - Set in Vercel Dashboard
VITE_API_URL=https://your-render-backend-url.onrender.com
